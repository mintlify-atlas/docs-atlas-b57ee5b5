  "keyFeatures": [
    "Runs in browsers, Node.js scripts, or serverless environments",
    "Control smart home devices (on/off/toggle) via cloud API",
    "Real-time device event listening via WebSocket",
    "Local LAN control via Zeroconf (no internet required)",
    "Power consumption monitoring for Sonoff POW devices",
    "Temperature and humidity sensor support",
    "Multi-channel device support (e.g., Sonoff 4CH)",
    "TypeScript type definitions included"
  ],
  "publicApiSurface": [
