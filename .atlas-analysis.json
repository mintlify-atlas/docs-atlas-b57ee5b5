{
  "projectType": "sdk-library",
  "projectName": "ewelink-api",
  "projectDescription": "A JavaScript/Node.js library for controlling eWeLink smart home devices (Sonoff) via the eWeLink API, supporting both cloud and local LAN (Zeroconf) modes.",
  "theme": "luma",
  "primaryColor": "#241c24",
