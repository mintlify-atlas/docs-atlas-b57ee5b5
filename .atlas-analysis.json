    "connection.toggleDevice(deviceId, channel?)",
    "connection.getDevicePowerUsage(deviceId)",
    "connection.getDevicePowerUsageRaw(deviceId)",
    "connection.getDeviceCurrentTH(deviceId)",
    "connection.getDeviceCurrentTemperature(deviceId)",
    "connection.getDeviceCurrentHumidity(deviceId)",
    "connection.getDeviceChannelCount(deviceId)",
